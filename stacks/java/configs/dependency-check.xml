<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
  <!--
    OWASP Dependency-Check Suppression Template for Java Projects

    Use this file to suppress false positives from dependency vulnerability scans.
    Each suppression should include:
    - Justification for why the CVE is suppressed
    - Expiration date (force re-evaluation)
    - Minimal scope (specific GAV coordinates when possible)

    Documentation: https://jeremylong.github.io/DependencyCheck/general/suppression.html
  -->

  <!-- Example: Suppress false positive for test dependency -->
  <!--
  <suppress>
    <notes>
      <![CDATA[
      CVE-2021-XXXXX is a false positive for JUnit 4.x when used only in test scope.
      The vulnerability requires runtime execution which does not occur in our test suite.
      Expires: 2026-12-31
      ]]>
    </notes>
    <packageUrl regex="true">^pkg:maven/junit/junit@.*$</packageUrl>
    <cve>CVE-2021-XXXXX</cve>
  </suppress>
  -->

  <!-- Example: Suppress known issue with mitigation in place -->
  <!--
  <suppress until="2026-06-30">
    <notes>
      <![CDATA[
      CVE-2022-YYYYY affects Log4j 2.x but we have mitigated via:
      - log4j2.formatMsgNoLookups=true JVM property
      - Restricted JNDI access via security manager
      - Awaiting upstream patch in Q2 2026
      ]]>
    </notes>
    <packageUrl regex="true">^pkg:maven/org\.apache\.logging\.log4j/log4j\-core@2\..*$</packageUrl>
    <vulnerabilityName>CVE-2022-YYYYY</vulnerabilityName>
  </suppress>
  -->

  <!-- Example: Suppress by file path for vendored dependencies -->
  <!--
  <suppress>
    <notes>
      <![CDATA[
      Vendored third-party library in lib/legacy/ is isolated and not exposed to external input.
      Scheduled for removal in v3.0 migration (Q3 2026).
      ]]>
    </notes>
    <filePath regex="true">.*[\\/]lib[\\/]legacy[\\/].*\.jar</filePath>
  </suppress>
  -->

  <!-- Example: Suppress by GAV coordinates -->
  <!--
  <suppress>
    <notes>
      <![CDATA[
      commons-collections 3.2.2 CVE only affects specific deserialization use cases.
      We do not deserialize untrusted data with this library.
      Validated via code review on 2026-02-01.
      ]]>
    </notes>
    <gav regex="true">^commons-collections:commons-collections:3\.2\.2$</gav>
    <cpe>cpe:/a:apache:commons_collections</cpe>
  </suppress>
  -->

  <!-- Template for new suppressions -->
  <!--
  <suppress until="YYYY-MM-DD">
    <notes>
      <![CDATA[
      [Justification]
      [Mitigation steps if applicable]
      [Timeline for resolution]
      ]]>
    </notes>
    <packageUrl regex="true">PACKAGE_URL_REGEX</packageUrl>
    <cve>CVE-YYYY-XXXXX</cve>
  </suppress>
  -->

</suppressions>
